<Shell
    x:Class="SmartGuideApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SmartGuideApp.Views"
    Shell.NavBarIsVisible="False">

    <TabBar Shell.TabBarTitleColor="#0F5BD7"
            Shell.TabBarUnselectedColor="#9CA3AF"
            Shell.TabBarForegroundColor="#0F5BD7">

        <ShellContent
            Title="Trang chủ"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent
            Title="Bản đồ"
            Icon="map.png"
            ContentTemplate="{DataTemplate views:MapPage}" />

        <ShellContent
            Title="Hồ sơ"
            Icon="account.png"
            ContentTemplate="{DataTemplate views:ProfilePage}" />

    </TabBar>

</Shell>