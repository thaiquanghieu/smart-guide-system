<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartGuideApp.Pages.RegisterPage"
             BackgroundColor="#041B2D"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <!-- LOGO -->
            <Image Source="appiconfg.png"
                   HeightRequest="200"
                   HorizontalOptions="Center"/>

            <Label Text="Đăng ký"
                   FontSize="24"
                   TextColor="White"
                   HorizontalOptions="Center"/>

            <!-- USERNAME -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="10">
                <Entry x:Name="UserNameEntry"
                       Placeholder="Tên người dùng"
                       TextColor="#0F5BD7"/>
            </Frame>

            <!-- EMAIL -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="10">
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"
                       Keyboard="Email"
                       TextColor="#0F5BD7"/>
            </Frame>

            <!-- PASSWORD -->
            <Frame BackgroundColor="White"
                CornerRadius="12"
                Padding="10">

                <Grid ColumnDefinitions="*,40">

                    <Entry x:Name="PasswordEntry"
                        Placeholder="Mật khẩu"
                        IsPassword="True"
                        TextColor="#0F5BD7"/>

                    <Image Grid.Column="1"
                        x:Name="TogglePasswordIcon"
                        Source="eye_close.png"
                        WidthRequest="20"
                        HeightRequest="20"
                        VerticalOptions="Center"
                        HorizontalOptions="Center">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTogglePassword"/>
                        </Image.GestureRecognizers>
                    </Image>

                </Grid>
            </Frame>

            <Frame BackgroundColor="White"
                CornerRadius="12"
                Padding="10">

                <Grid ColumnDefinitions="*,40">

                    <Entry x:Name="ConfirmPasswordEntry"
                        Placeholder="Nhập lại mật khẩu"
                        IsPassword="True"
                        TextColor="#0F5BD7"/>

                    <Image Grid.Column="1"
                        x:Name="ToggleConfirmPasswordIcon"
                        Source="eye_closed.png"
                        WidthRequest="20"
                        HeightRequest="20"
                        VerticalOptions="Center"
                        HorizontalOptions="Center">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleConfirmPassword"/>
                        </Image.GestureRecognizers>
                    </Image>

                </Grid>
            </Frame>

            <Button Text="Đăng ký"
                    BackgroundColor="#0F5BD7"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="50"
                    Clicked="OnRegisterClicked"/>

            <!-- BACK LOGIN -->
            <Label Text="Đã có tài khoản? Đăng nhập"
                   TextColor="#0F5BD7"
                   HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoLogin"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>