<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SmartGuideApp.ViewModels"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="SmartGuideApp.Views.HomePage"
             BackgroundColor="#F4F7FB">

    <ContentPage.BindingContext>
        <viewmodels:HomeViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Padding="24,18,24,10"
              ColumnDefinitions="46,*,46">
            <Image Source="menu.png"
                   WidthRequest="28"
                   HeightRequest="28"
                   HorizontalOptions="Start"
                   VerticalOptions="Center" />

            <Label Grid.Column="1"
                   Text="Smart Guide"
                   FontSize="25"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="#0B63E5" />

            <Grid Grid.Column="2"
                  WidthRequest="42"
                  HeightRequest="42"
                  HorizontalOptions="End"
                  VerticalOptions="Center">

                <Image Source="notifications.png"
                       WidthRequest="26"
                       HeightRequest="26"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <Frame WidthRequest="18"
                       HeightRequest="18"
                       Padding="0"
                       CornerRadius="9"
                       BackgroundColor="#FF3B30"
                       HorizontalOptions="End"
                       VerticalOptions="Start"
                       HasShadow="False"
                       Margin="0,1,0,0">
                    <Label Text="1"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
            </Grid>
        </Grid>

        <!-- Content -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Pois}"
                        SelectionMode="None"
                        BackgroundColor="Transparent"
                        Margin="0,0,0,8">

            <CollectionView.Header>
                <VerticalStackLayout Padding="24,0,24,22"
                                     Spacing="18">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="HÀNH TRÌNH CỦA BẠN"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#0F5BD7" />

                        <Label Text="Xin chào! Bạn muốn đi đâu hôm nay?"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Search -->
                    <Frame CornerRadius="12"
                           Padding="0"
                           HeightRequest="60"
                           BackgroundColor="White"
                           BorderColor="#D1D5DB"
                           HasShadow="False">

                        <Grid Padding="12,0,12,0"
                              ColumnDefinitions="48,*,Auto"
                              HeightRequest="60"
                              ColumnSpacing="6">

                            <Image Source="search.png"
                                   WidthRequest="30"
                                   HeightRequest="30"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />

                            <Entry Grid.Column="1"
                                   x:Name="SearchEntry"
                                   Text="{Binding SearchText}"
                                   Focused="OnSearchFocused"
                                   Unfocused="OnSearchUnfocused"
                                   Placeholder="Tìm kiếm địa điểm..."
                                   PlaceholderColor="#6C8FD8"
                                   TextColor="#0F5BD7"
                                   BackgroundColor="Transparent"
                                   ClearButtonVisibility="WhileEditing"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="2"
                                   Text="Huỷ"
                                   FontSize="14"
                                   TextColor="#0F5BD7"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding IsSearchActive}">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCancelSearch" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Frame>

                    <!-- Suggestions box: động, nằm ngay dưới search bar -->
                    <Border Margin="0,-15,0,0"
                            Padding="0"
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            IsVisible="{Binding IsSuggestionVisible}"
                            VerticalOptions="Start"
                            ZIndex="10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <CollectionView ItemsSource="{Binding Suggestions}"
                                        SelectionMode="None"
                                        BackgroundColor="Transparent"
                                        MaximumHeightRequest="220">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,10"
                                          ColumnDefinitions="*,Auto"
                                          RowDefinitions="Auto,Auto">
                                        <Label Text="{Binding Name}"
                                               MaxLines="1"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               Grid.Row="0"
                                               Grid.Column="0"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding SuggestionDistanceText}"
                                               FontSize="12"
                                               TextColor="#6B7280"
                                               HorizontalTextAlignment="End"
                                               Grid.Row="0"
                                               Grid.Column="1" />
                                        <Label Text="{Binding Address}"
                                               FontSize="12"
                                               TextColor="#6B7280"
                                               Grid.Row="1"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="2"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSuggestionTapped"
                                                                  CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <!-- Current location -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Vị trí hiện tại"
                               FontSize="27"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Frame CornerRadius="20"
                               Padding="0"
                               HasShadow="False"
                               BackgroundColor="#0E9EC2"
                               HeightRequest="200">
                            <Frame CornerRadius="20"
                                   Padding="0"
                                   HasShadow="False"
                                   BackgroundColor="White"
                                   HeightRequest="200">

                                <Grid>
                                    <maps:Map x:Name="PreviewMap"
                                              IsShowingUser="True"
                                              MapClicked="OnMapClicked" />

                                    <Frame WidthRequest="54"
                                           HeightRequest="54"
                                           CornerRadius="18"
                                           BackgroundColor="White"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           Margin="0,12,12,0"
                                           ZIndex="2">

                                        <Frame.Shadow>
                                            <Shadow Brush="#000000"
                                                    Opacity="0.10"
                                                    Radius="10"
                                                    Offset="3,4" />
                                        </Frame.Shadow>

                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnMyLocationClicked" />
                                        </Frame.GestureRecognizers>

                                        <Image Source="location.png"
                                               WidthRequest="26"
                                               HeightRequest="26"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Frame>
                                </Grid>
                            </Frame>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Main option + filter/sort -->
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="0"
                          Margin="0,2,0,0">

                        <!-- Left -->
                        <HorizontalStackLayout Grid.Column="0"
                                               Spacing="6"
                                               HorizontalOptions="Start">
                            <Label x:Name="MainOptionText"
                                   Text="Gần bạn"
                                   FontSize="27"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Image Source="dropdown.png"
                                   WidthRequest="14"
                                   HeightRequest="14"
                                   VerticalOptions="End"
                                   Margin="0,0,0,5" />

                            <HorizontalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOpenMainDropdown" />
                            </HorizontalStackLayout.GestureRecognizers>
                        </HorizontalStackLayout>

                        <!-- Right -->
                        <HorizontalStackLayout Grid.Column="1"
                                               Spacing="8"
                                               HorizontalOptions="End">

                            <Frame Padding="10,6"
                                   CornerRadius="10"
                                   BorderColor="#E5E7EB"
                                   BackgroundColor="White"
                                   HasShadow="False">
                                <HorizontalStackLayout Spacing="6">
                                    <Image x:Name="FilterIcon"
                                           Source="filter.png"
                                           WidthRequest="16"
                                           HeightRequest="16" />

                                    <Label x:Name="FilterText"
                                           Text="Lọc"
                                           FontSize="13"
                                           TextColor="#9CA3AF" />
                                </HorizontalStackLayout>

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <Frame Padding="10,6"
                                   CornerRadius="10"
                                   BorderColor="#E5E7EB"
                                   BackgroundColor="White"
                                   HasShadow="False">
                                <HorizontalStackLayout Spacing="6">
                                    <Image x:Name="SortIcon"
                                           Source="sort.png"
                                           WidthRequest="16"
                                           HeightRequest="16" />

                                    <Label x:Name="SortText"
                                           Text="Sắp xếp"
                                           FontSize="13"
                                           TextColor="#9CA3AF" />
                                </HorizontalStackLayout>

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSortClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                        </HorizontalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="24,0">
                        <Frame Margin="0,0,0,16"
                               Padding="0"
                               CornerRadius="16"
                               BackgroundColor="White"
                               HasShadow="False">

                            <Grid RowDefinitions="145,Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnOpenDetailTapped"
                                                          CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <!-- Image -->
                                <Grid>
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill" />

                                    <!-- Category -->
                                    <Frame Margin="14,14,0,0"
                                           Padding="12,6"
                                           CornerRadius="12"
                                           BackgroundColor="#FFF4E5"
                                           HorizontalOptions="Start"
                                           VerticalOptions="Start"
                                           HasShadow="False">
                                        <Label Text="{Binding Category}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#B45309" />
                                    </Frame>

                                    <!-- Distance -->
                                    <Frame Margin="0,14,14,0"
                                           Padding="12,6"
                                           CornerRadius="12"
                                           BackgroundColor="#EEF4FF"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           HasShadow="False">
                                        <Label Text="{Binding DistanceKm, StringFormat='{}{0:0.0} km'}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#365FA8" />
                                    </Frame>

                                    <!-- Rating -->
                                    <HorizontalStackLayout HorizontalOptions="End"
                                                           VerticalOptions="End"
                                                           Margin="0,0,14,14"
                                                           Spacing="4">
                                        <Image Source="star.png"
                                               WidthRequest="14"
                                               HeightRequest="14" />

                                        <Label Text="4.1"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                    </HorizontalStackLayout>
                                </Grid>

                                <!-- Content -->
                                <Grid Grid.Row="1"
                                      Padding="16,12,16,10"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontSize="21"
                                               FontAttributes="Bold"
                                               TextColor="#111827"
                                               LineBreakMode="TailTruncation" />

                                        <Label Text="{Binding Address}"
                                               FontSize="14"
                                               TextColor="#5B6474"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <Label Text="Xem chi tiết"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#0F5BD7"
                                               Margin="0,2,0,0" />
                                    </VerticalStackLayout>

                                    <Frame Grid.Column="1"
                                           WidthRequest="44"
                                           HeightRequest="44"
                                           Padding="0"
                                           CornerRadius="22"
                                           BackgroundColor="#F3F7FF"
                                           VerticalOptions="Center"
                                           HasShadow="False">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFavoriteTapped"
                                                                  CommandParameter="{Binding .}" />
                                        </Frame.GestureRecognizers>

                                        <Image WidthRequest="20"
                                               HeightRequest="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">

                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding IsFavorite}"
                                                             Value="True">
                                                    <Setter Property="Source" Value="favorite_active.png" />
                                                </DataTrigger>

                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding IsFavorite}"
                                                             Value="False">
                                                    <Setter Property="Source" Value="favorite.png" />
                                                </DataTrigger>
                                            </Image.Triggers>

                                        </Image>
                                    </Frame>
                                </Grid>
                            </Grid>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="12"
                         Color="Transparent" />
            </CollectionView.Footer>
        </CollectionView>


        <!-- Toast overlay -->
        <Frame x:Name="ToastView"
               Grid.RowSpan="2"
               IsVisible="False"
               Opacity="0"
               TranslationY="-30"
               BackgroundColor="#CCEEF4FF"
               BorderColor="#8CB7FF"
               CornerRadius="14"
               Padding="16,10"
               HasShadow="False"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="0,78,0,0">

            <Label x:Name="ToastText"
                   Text="Đã thêm vào yêu thích!"
                   FontSize="13"
                   TextColor="#0F5BD7"
                   FontAttributes="Bold" />
        </Frame>
    </Grid>
</ContentPage>