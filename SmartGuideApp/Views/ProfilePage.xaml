<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SmartGuideApp.ViewModels"
             x:Class="SmartGuideApp.Views.ProfilePage"
             BackgroundColor="#F4F7FC">

    <ContentPage.BindingContext>
        <viewmodels:ProfileViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="18"
                             Padding="0,0,0,28">

            <Grid Padding="20,16,20,14"
                  ColumnDefinitions="Auto,*"
                  BackgroundColor="White">
                <Label Text="☰"
                       FontSize="22"
                       TextColor="#0058BC"
                       VerticalOptions="Center" />

                <Label Grid.Column="1"
                       Text="Smart Guide"
                       HorizontalOptions="Center"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#0058BC"
                       VerticalOptions="Center" />
            </Grid>

            <VerticalStackLayout Padding="20,18,20,0"
                                 Spacing="14"
                                 HorizontalOptions="Center">
                <Grid WidthRequest="140"
                      HeightRequest="140">
                    <Frame WidthRequest="140"
                           HeightRequest="140"
                           Padding="6"
                           CornerRadius="70"
                           BackgroundColor="#60A5FA"
                           HasShadow="False">
                        <Frame WidthRequest="128"
                               HeightRequest="128"
                               Padding="0"
                               CornerRadius="64"
                               BackgroundColor="White">
                            <Image Source="{Binding AvatarUrl}"
                                   Aspect="AspectFill" />
                        </Frame>
                    </Frame>

                    <Frame WidthRequest="44"
                           HeightRequest="44"
                           Padding="0"
                           CornerRadius="22"
                           BackgroundColor="#0058BC"
                           HorizontalOptions="End"
                           VerticalOptions="End">
                        <Label Text="✎"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Frame>
                </Grid>

                <VerticalStackLayout Spacing="4"
                                     HorizontalOptions="Center">
                    <Label Text="{Binding UserName}"
                           FontSize="32"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{Binding Email}"
                           FontSize="16"
                           TextColor="#6B7280"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Grid Padding="20,0,20,0"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="18">
                <Frame Padding="22"
                       CornerRadius="24"
                       BackgroundColor="White">
                    <VerticalStackLayout Spacing="8"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding FavoriteCount}"
                               FontSize="36"
                               FontAttributes="Bold"
                               TextColor="#0058BC"
                               HorizontalTextAlignment="Center" />
                        <Label Text="YÊU THÍCH"
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1"
                       Padding="22"
                       CornerRadius="24"
                       BackgroundColor="White">
                    <VerticalStackLayout Spacing="8"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding ListenedPoiCount}"
                               FontSize="36"
                               FontAttributes="Bold"
                               TextColor="#3B49DF"
                               HorizontalTextAlignment="Center" />
                        <Label Text="ĐIỂM ĐÃ NGHE"
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Frame Margin="20,6,20,0"
                   Padding="0"
                   CornerRadius="28"
                   BackgroundColor="White">
                <VerticalStackLayout Spacing="0">

                    <Grid Padding="22"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="16">
                        <Frame WidthRequest="54"
                               HeightRequest="54"
                               Padding="0"
                               CornerRadius="18"
                               BackgroundColor="#EEF4FF">
                            <Label Text="↺"
                                   FontSize="26"
                                   TextColor="#0058BC"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <Label Grid.Column="1"
                               Text="Lịch sử nghe"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="26"
                               TextColor="#B0B7C3"
                               VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="#F1F5F9" />

                    <Grid Padding="22"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="16">
                        <Frame WidthRequest="54"
                               HeightRequest="54"
                               Padding="0"
                               CornerRadius="18"
                               BackgroundColor="#FCE7F3">
                            <Label Text="♥"
                                   FontSize="22"
                                   TextColor="#EC4899"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <Label Grid.Column="1"
                               Text="Địa điểm yêu thích"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="26"
                               TextColor="#B0B7C3"
                               VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="#F1F5F9" />

                    <Grid Padding="22"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="16">
                        <Frame WidthRequest="54"
                               HeightRequest="54"
                               Padding="0"
                               CornerRadius="18"
                               BackgroundColor="#EEF2F7">
                            <Label Text="⚙"
                                   FontSize="24"
                                   TextColor="#475569"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <Label Grid.Column="1"
                               Text="Cài đặt"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="26"
                               TextColor="#B0B7C3"
                               VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="#F1F5F9" />

                    <Grid Padding="22"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="16">
                        <Frame WidthRequest="54"
                               HeightRequest="54"
                               Padding="0"
                               CornerRadius="18"
                               BackgroundColor="#ECFDF5">
                            <Label Text="☏"
                                   FontSize="22"
                                   TextColor="#16A34A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <Label Grid.Column="1"
                               Text="Liên hệ hỗ trợ"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="26"
                               TextColor="#B0B7C3"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Margin="20,0,20,0"
                   Padding="22"
                   CornerRadius="28"
                   BackgroundColor="White">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="16">
                    <Frame WidthRequest="54"
                           HeightRequest="54"
                           Padding="0"
                           CornerRadius="18"
                           BackgroundColor="#FEF2F2">
                        <Label Text="↪"
                               FontSize="24"
                               TextColor="#DC2626"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Frame>

                    <Label Grid.Column="1"
                           Text="Đăng xuất"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#DC2626"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <VerticalStackLayout Padding="20,18,20,0"
                                 Spacing="8">
                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="24">
                    <Label Text="Điều khoản"
                           FontSize="14"
                           TextColor="#374151" />
                    <Label Text="Bảo mật"
                           FontSize="14"
                           TextColor="#374151" />
                    <Label Text="Về chúng tôi"
                           FontSize="14"
                           TextColor="#374151" />
                </HorizontalStackLayout>

                <Label Text="© 2024 SMART GUIDE VIETNAM"
                       HorizontalTextAlignment="Center"
                       FontSize="12"
                       TextColor="#9CA3AF" />

                <Label Text="Version 2.4.0"
                       HorizontalTextAlignment="Center"
                       FontSize="12"
                       TextColor="#C0C6D1" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>