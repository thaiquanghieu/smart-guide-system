<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="SmartGuideApp.Views.MapPage"
             BackgroundColor="#F3F4F6">

    <Grid>

        <!-- MAP -->
        <maps:Map x:Name="MainMap"
                  MapClicked="OnMapClicked"
                  IsShowingUser="True" />

        <!-- SEARCH BAR -->
        <Frame Margin="16,50,16,0"
               CornerRadius="12"
               Padding="10"
               BackgroundColor="White"
               HasShadow="True"
               VerticalOptions="Start">

            <Entry Placeholder="Tìm địa điểm..."
                   TextColor="Black"/>

        </Frame>

        <!-- BOTTOM INFO -->
        <Frame IsVisible="{Binding IsPoiSelected}"
               VerticalOptions="End"
               Margin="16"
               CornerRadius="16"
               Padding="16"
               BackgroundColor="White"
               HasShadow="True">

            <VerticalStackLayout>

                <Label Text="{Binding Title}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="Black"/>

                <Label Text="{Binding Category}"
                       FontSize="14"
                       TextColor="#6B7280"/>

                <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">

                    <Button Text="Chi tiết"
                            Clicked="OnOpenDetailClicked"
                            BackgroundColor="#0F5BD7"
                            TextColor="White"/>

                </HorizontalStackLayout>

            </VerticalStackLayout>

        </Frame>

    </Grid>
</ContentPage>