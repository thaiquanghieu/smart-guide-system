<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="SmartGuideApp.Views.MapPage"
             BackgroundColor="#F4F7FB">

    <Grid>

        <!-- MAP -->
        <maps:Map x:Name="MainMap"
                  MapClicked="OnMapClicked"
                  IsShowingUser="True" />

        <!-- HEADER -->
        <Grid VerticalOptions="Start"
              HeightRequest="70"
              ZIndex="2"
              InputTransparent="True">

            <BoxView Color="#F4F7FB"/>

            <Label Text="Smart Guide"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#0F5BD7"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

        </Grid>

        <!-- SEARCH -->
        <Frame Margin="16,80,16,0"
               CornerRadius="22"
               Padding="14,10"
               BackgroundColor="White"
               HasShadow="True"
               VerticalOptions="Start"
               ZIndex="2">

            <Frame.Shadow>
                <Shadow Brush="#000000"
                        Opacity="0.08"
                        Radius="12"
                        Offset="0,4"/>
            </Frame.Shadow>

            <Grid ColumnDefinitions="30,*">

                <Image Source="search.png"
                       WidthRequest="26"
                       HeightRequest="26"
                       VerticalOptions="Center"/>

                <Entry Grid.Column="1"
                       Placeholder="Tìm kiếm địa điểm..."
                       TextColor="Black"/>

            </Grid>
        </Frame>

        <!-- LOCATION BUTTON (VỊ TRÍ CŨ) -->
        <Frame WidthRequest="54"
               HeightRequest="54"
               CornerRadius="18"
               BackgroundColor="White"
               HasShadow="True"
               HorizontalOptions="End"
               VerticalOptions="Start"
               Margin="0,190,16,0"
               ZIndex="2">

            <Frame.Shadow>
                <Shadow Brush="#000000"
                        Opacity="0.08"
                        Radius="12"
                        Offset="0,4"/>
            </Frame.Shadow>

            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMyLocationClicked"/>
            </Frame.GestureRecognizers>

            <Image Source="location.png"
                   WidthRequest="26"
                   HeightRequest="26"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

        </Frame>

        <!-- CARD -->
        <Frame IsVisible="{Binding IsPoiSelected}"
               VerticalOptions="End"
               Margin="16,0,16,20"
               CornerRadius="22"
               Padding="16"
               BackgroundColor="White"
               HasShadow="True"
               ZIndex="3">

            <Frame.Shadow>
                <Shadow Brush="#000000"
                        Opacity="0.1"
                        Radius="16"
                        Offset="0,6"/>
            </Frame.Shadow>

            <VerticalStackLayout Spacing="12">

                <!-- TOP -->
                <Grid ColumnDefinitions="100,*" ColumnSpacing="12">

                    <!-- AVATAR -->
                    <Frame Padding="0"
                           CornerRadius="18"
                           BorderColor="#E5E7EB"
                           HasShadow="False"
                           WidthRequest="100"
                           HeightRequest="100">

                        <Image Source="{Binding ImageUrl}"
                               Aspect="AspectFill"/>
                    </Frame>

                    <!-- INFO -->
                    <VerticalStackLayout Grid.Column="1" Spacing="4">

                        <Label Text="{Binding Category}"
                               FontSize="12"
                               TextColor="#0F5BD7"/>

                        <Label Text="{Binding Title}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="Black"/>

                        <HorizontalStackLayout Spacing="6">
                            <Image Source="star.png" WidthRequest="14"/>
                            <Label Text="{Binding RatingText}" FontSize="14"/>
                        </HorizontalStackLayout>

                        <Label Text="{Binding DistanceText}"
                               FontSize="14"
                               TextColor="#0F5BD7"/>

                        <Label Text="{Binding Address}"
                               FontSize="12"
                               TextColor="#6B7280"
                               LineBreakMode="TailTruncation"/>

                    </VerticalStackLayout>

                </Grid>

                <!-- BUTTONS -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                    <Button Text="Chỉ đường"
                            BackgroundColor="#0F5BD7"
                            TextColor="White"
                            CornerRadius="16"
                            HeightRequest="50"/>

                    <Button Grid.Column="1"
                            Text="Chi tiết"
                            BackgroundColor="#E5E7EB"
                            TextColor="#0F5BD7"
                            CornerRadius="16"
                            HeightRequest="50"
                            Clicked="OnOpenDetailClicked"/>

                </Grid>

            </VerticalStackLayout>

        </Frame>

    </Grid>
</ContentPage>